{
  /*
   * ─────────────────────────────────────────────────────────────────────────
   *  appsettings.json — PRODUCTION / SHARED DEFAULTS
   * ─────────────────────────────────────────────────────────────────────────
   *  This file is committed to source control and must NEVER contain secrets.
   *
   *  All sensitive values (passwords, API keys, tokens, connection strings)
   *  must be provided via:
   *    - Local dev: dotnet user-secrets  (see docs/DEVELOPMENT-SETUP.md)
   *    - Production: Environment variables or a secrets manager
   *
   *  Non-sensitive defaults (e.g. log levels, feature flags, server names
   *  without credentials) are safe to commit here.
   * ─────────────────────────────────────────────────────────────────────────
   */
  "ConnectionStrings": {
    /*
     * Override per environment. Format for PostgreSQL:
     *   Host=HOST;Port=5432;Database=SystenicsAppDeployment;Username=USER;Password=PASS;
     *
     * Never commit the real password here.
     */
    "DefaultConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FormAccess": {
    /*
     * ApiKey — Admin API key required in the X-Api-Key header when issuing tokens.
     * Provide via environment variable:  FormAccess__ApiKey=...
     * Or user-secrets:  dotnet user-secrets set "FormAccess:ApiKey" "..."
     */
    "ApiKey": "",
    /*
     * PublicBaseUrl — Optional. Overrides the host used when building client
     * form URLs in API responses. Set to your production domain or ngrok URL.
     * Example: https://deploy.example.com
     */
    "PublicBaseUrl": "https://nephew-unadorned-prototype.ngrok-free.dev"
  },
  "MailgunSMTP": {
    /*
     * Non-secret defaults (server and port are the same across environments).
     * Credentials (SMTPUsername, SMTPPassword, FromEmail) must be in user-secrets
     * or environment variables — never committed here.
     */
    "SMTPServer": "smtp.mailgun.org",
    "SMTPPort": 587,
    "SMTPUsername": "",
    "SMTPPassword": "",
    "FromEmail": "",
    "FromDisplayName": "Systenics App Deployment"
  },
  "GitHub": {
    /*
     * Enabled — set false to skip GitHub API calls in CI/testing environments.
     */
    "Enabled": true,
    "Owner": "JayeshPatil2023",
    "CreateRepositoryEndpoint": "https://api.github.com/user/repos",
    /*
     * PersonalAccessToken — provide via GITHUB_TOKEN environment variable
     * (preferred) or user-secrets. Never commit the real token here.
     */
    "PersonalAccessToken": "",
    "WorkflowDispatch": {
      "Enabled": true,
      "Owner": "systenics",
      "Repository": "SA_BaseMVCProject",
      "Workflow": "main.yml",
      "Ref": "master",
      "ClientName": "BidMaster",
      "ClientBranch": "master_dev",
      "SourceName": "AuctionPro_05",
      "SourceBranch": "master_dev",
      /*
       * PublicBaseUrl — must be publicly reachable by GitHub Actions runners.
       * GitHub Actions runners cannot reach localhost. Use your production
       * URL or an ngrok tunnel. Provide via user-secrets or environment variable.
       */
      "PublicBaseUrl": "https://nephew-unadorned-prototype.ngrok-free.dev",
      "MaxRetries": 3,
      "RetryDelaySeconds": 5
    }
  },
  "Storage": {
    /*
     * StorageType — Local uses wwwroot/uploads via LocalAssetStorageService.
     * Azure Blob / S3 can be added later by implementing IAssetStorageService
     * and setting StorageType accordingly (see docs/DEVELOPMENT-SETUP.md).
     */
    "StorageType": "Local"
  }
}

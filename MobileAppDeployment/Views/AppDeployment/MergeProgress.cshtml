@model MobileAppDeployment.Models.MergeProgressViewModel
@{
    ViewData["Title"] = "Merging source code";
}

<div class="page-header-row">
    <div>
        <p class="page-title" style="margin-bottom:0">Merging source code</p>
        <p class="page-sub" style="margin-bottom:0">
            Copying source repository into <strong>@Model.ClientRepoName</strong>
        </p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.RepoCreatedMessage))
{
    <div class="alert-banner alert-banner--success" role="alert">
        <span>@Model.RepoCreatedMessage</span>
    </div>
}

<div class="data-card merge-progress-card" id="merge-progress-root"
     data-job-id="@Model.JobId"
     data-status-url="@Url.Action("MergeStatus", new { jobId = Model.JobId })"
     data-index-url="@Url.Action("Index")">
    <div class="merge-progress-card__header">
        <h2 class="merge-progress-card__title">@Model.AppName</h2>
        @if (!string.IsNullOrWhiteSpace(Model.RepositoryUrl))
        {
            <a href="@Model.RepositoryUrl" target="_blank" rel="noopener" class="merge-progress-card__repo-link">
                @Model.RepositoryUrl
            </a>
        }
    </div>

    <div class="merge-progress-bar" role="progressbar"
         aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"
         id="merge-progress-bar">
        <div class="merge-progress-bar__fill" id="merge-progress-fill" style="width:0%"></div>
    </div>

    <p class="merge-progress-status" id="merge-progress-message">Preparing merge...</p>
    <p class="merge-progress-meta" id="merge-progress-attempt" hidden></p>

    <div class="alert-banner alert-banner--success merge-result-banner" id="merge-success-banner" hidden role="alert">
        <span id="merge-success-text"></span>
    </div>

    <div class="alert-banner alert-banner--danger merge-result-banner" id="merge-error-banner" hidden role="alert">
        <span id="merge-error-text"></span>
    </div>

    <div class="merge-progress-actions" id="merge-progress-actions" hidden>
        <a asp-action="Index" class="btn btn-primary">Back to deployments</a>
    </div>
</div>

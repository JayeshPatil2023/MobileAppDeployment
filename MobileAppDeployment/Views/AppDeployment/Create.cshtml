@model MobileAppDeployment.Models.AppDeployment
@{
    ViewData["Title"] = "Create App Deployment";
    ViewData["FormLayout"] = true;
    string? formToken = ViewBag.FormToken as string;
    ViewBag.DeploymentId = null;
}

<p class="page-title">New app deployment</p>
<p class="page-sub">
    Fields marked <span style="color:var(--danger)">*</span> are required before you start deployment.
    You can save a draft with only <strong>Organization Name</strong> and <strong>App Name</strong> filled.
</p>

<partial name="_DeploymentAlerts" />

<form asp-action="Create" asp-route-token="@formToken" method="post" enctype="multipart/form-data" id="deployment-form" novalidate>
    <input type="hidden" name="token" value="@formToken" />
    <div asp-validation-summary="All"></div>

    <partial name="_FormFields" model="Model" />
</form>

<partial name="_DeploymentFormFooter" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_SaveOnlyClientValidation" />
}

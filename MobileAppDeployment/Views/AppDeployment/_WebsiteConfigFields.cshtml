@model MobileAppDeployment.Models.AppDeployment

<div class="section" id="sec-website">
    <div class="section-header">
        <div class="section-icon icon-website">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
        </div>
        <div class="section-title-group">
            <div class="section-title">Website configuration</div>
            <div class="section-desc">Domain must be pointed to your host before deployment. SSL is auto-provisioned.</div>
        </div>
        <span class="section-badge badge-required">Required</span>
    </div>
    <div class="section-body">
        <div class="field">
            <label asp-for="DomainUrl" class="field-label">Domain <span class="required">*</span></label>
            <input asp-for="DomainUrl" class="form-input" type="url" placeholder="https://yourapp.com" />
            <span asp-validation-for="DomainUrl" class="field-error"></span>
            <span class="field-hint">Point your domain's A record to the deployment server. A free SSL certificate will be issued automatically via Let's Encrypt.</span>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-banner alert-banner--success" role="alert">
        <span>@TempData["SuccessMessage"]</span>
        <button type="button" class="alert-close" data-dismiss="alert" aria-label="Close">&times;</button>
    </div>
}

@if (TempData["WarningMessage"] != null)
{
    <div class="alert-banner alert-banner--warn" role="alert">
        <span>@TempData["WarningMessage"]</span>
        <button type="button" class="alert-close" data-dismiss="alert" aria-label="Close">&times;</button>
    </div>
}

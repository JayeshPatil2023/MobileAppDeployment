@{
    int? deploymentId = ViewBag.DeploymentId as int?;
    string? formToken = ViewBag.FormToken as string;
    bool canStartDeployment = deploymentId is > 0;
    bool tokenEdit = !string.IsNullOrEmpty(formToken);
}

@if (canStartDeployment)
{
    <p class="footer-save-reminder cell-muted">
        Made changes? Click <strong>Save Deployment</strong> before starting the process so your latest updates are used.
    </p>
}

<div class="form-footer">
    @if (tokenEdit)
    {
        <span class="footer-hint cell-muted">Use your original form link anytime to continue editing.</span>
    }
    else if (canStartDeployment)
    {
        <a asp-action="Index" class="btn btn-ghost">Back to list</a>
    }
    else
    {
        <span class="footer-hint cell-muted">Secure token form — bookmark this page link to return later.</span>
    }

    <div class="footer-right">
        <partial name="_StartDeploymentButton" />
        <button type="submit" class="btn btn-primary" form="deployment-form">Save Deployment</button>
    </div>
</div>

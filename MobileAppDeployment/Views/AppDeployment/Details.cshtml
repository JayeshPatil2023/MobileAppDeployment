@model MobileAppDeployment.Models.AppDeployment
@{
    ViewData["Title"] = "App Deployment Details";
}

<div class="page-header-row">
    <div>
        <p class="page-title" style="margin-bottom:0">@Model.AppName</p>
        <p class="page-sub" style="margin-bottom:0">Deployment configuration details</p>
    </div>
    <div class="footer-right">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-ghost">Back to list</a>
    </div>
</div>

<div class="section">
    <div class="section-header">
        <div class="section-icon icon-org">
            <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <div class="section-title-group">
            <div class="section-title">Certificate / organization details</div>
        </div>
    </div>
    <div class="section-body">
        <div class="detail-grid">
            <div class="detail-item"><div class="detail-label">Common name</div><div class="detail-value">@Model.CommonName</div></div>
            <div class="detail-item"><div class="detail-label">Organization unit</div><div class="detail-value">@Model.OrganizationUnit</div></div>
            <div class="detail-item"><div class="detail-label">Organization name</div><div class="detail-value">@Model.OrganizationName</div></div>
            <div class="detail-item"><div class="detail-label">Locality</div><div class="detail-value">@Model.LocalityName</div></div>
            <div class="detail-item"><div class="detail-label">State</div><div class="detail-value">@Model.StateName</div></div>
            <div class="detail-item"><div class="detail-label">Country</div><div class="detail-value">@Model.Country</div></div>
            <div class="detail-item"><div class="detail-label">Admin email</div><div class="detail-value">@Model.AdminEmail</div></div>
            <div class="detail-item detail-item--full"><div class="detail-label">Domain</div><div class="detail-value">@Model.DomainUrl</div></div>
        </div>
    </div>
</div>

<div class="section">
    <div class="section-header">
        <div class="section-icon icon-app">
            <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        </div>
        <div class="section-title-group">
            <div class="section-title">General app details</div>
        </div>
    </div>
    <div class="section-body">
        <div class="detail-grid">
            <div class="detail-item"><div class="detail-label">App name</div><div class="detail-value">@Model.AppName</div></div>
            <div class="detail-item detail-item--full"><div class="detail-label">Short description</div><div class="detail-value">@Model.ShortDescription</div></div>
            <div class="detail-item detail-item--full"><div class="detail-label">Full description</div><div class="detail-value">@Model.FullDescription</div></div>
        </div>
    </div>
</div>

<div class="section">
    <div class="section-header">
        <div class="section-icon icon-mobile">
            <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        </div>
        <div class="section-title-group">
            <div class="section-title">Mobile configuration</div>
        </div>
    </div>
    <div class="section-body">
        <div class="detail-grid">
            <div class="detail-item"><div class="detail-label">Package name</div><div class="detail-value">@Model.AndroidPackageName</div></div>
            <div class="detail-item"><div class="detail-label">Google Play listing URL</div><div class="detail-value">@(string.IsNullOrEmpty(Model.GooglePlayListingUrl) ? "—" : Model.GooglePlayListingUrl)</div></div>
            <div class="detail-item"><div class="detail-label">Play Store key JSON</div><div class="detail-value">@(string.IsNullOrEmpty(Model.PlayStoreKeyPath) ? "Not uploaded" : "Uploaded")</div></div>
            <div class="detail-item"><div class="detail-label">iOS Bundle ID</div><div class="detail-value">@Model.IosBundleId</div></div>
            <div class="detail-item"><div class="detail-label">Apple Team ID</div><div class="detail-value">@Model.AppleTeamId</div></div>
            <div class="detail-item"><div class="detail-label">Apple Issuer ID</div><div class="detail-value">@Model.AppleIssuerId</div></div>
            <div class="detail-item"><div class="detail-label">Apple Key ID</div><div class="detail-value">@Model.AppleKeyId</div></div>
            <div class="detail-item"><div class="detail-label">Apple Auth Key (.p8)</div><div class="detail-value">@(string.IsNullOrEmpty(Model.AppleAuthKeyPath) ? "Not uploaded" : "Uploaded")</div></div>
        </div>
    </div>
</div>

<div class="section">
    <div class="section-header">
        <div class="section-icon icon-apple">
            <svg viewBox="0 0 24 24"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0017 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 00-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06z"/><path d="M10 2c1 .5 2 2 2 5"/></svg>
        </div>
        <div class="section-title-group">
            <div class="section-title">Apple app listing</div>
        </div>
    </div>
    <div class="section-body">
        <div class="detail-grid">
            <div class="detail-item"><div class="detail-label">Name</div><div class="detail-value">@Model.AppleName</div></div>
            <div class="detail-item"><div class="detail-label">Subtitle</div><div class="detail-value">@Model.AppleSubtitle</div></div>
            <div class="detail-item detail-item--full"><div class="detail-label">Promotional text</div><div class="detail-value">@(Model.ApplePromotionalText ?? "—")</div></div>
            <div class="detail-item detail-item--full"><div class="detail-label">Description</div><div class="detail-value">@Model.AppleDescription</div></div>
            <div class="detail-item detail-item--full"><div class="detail-label">Keywords</div><div class="detail-value">@Model.AppleKeywords</div></div>
            <div class="detail-item"><div class="detail-label">Support URL</div><div class="detail-value">@(string.IsNullOrEmpty(Model.AppleSupportUrl) ? "—" : Model.AppleSupportUrl)</div></div>
            <div class="detail-item"><div class="detail-label">Marketing URL</div><div class="detail-value">@(string.IsNullOrEmpty(Model.AppleMarketingUrl) ? "—" : Model.AppleMarketingUrl)</div></div>
            <div class="detail-item detail-item--full"><div class="detail-label">Copyright</div><div class="detail-value">@Model.AppleCopyright</div></div>
        </div>
    </div>
</div>

<div class="section">
    <div class="section-header">
        <div class="section-icon icon-assets">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </div>
        <div class="section-title-group">
            <div class="section-title">Assets</div>
        </div>
    </div>
    <div class="section-body">
        <div class="asset-preview-grid">
            <div class="asset-preview-card">
                <div class="detail-label">Mobile app icon</div>
                @if (!string.IsNullOrEmpty(Model.MobileAppIconPath)) { <img src="@Model.MobileAppIconPath" alt="Mobile app icon" /> }
                else { <div class="detail-value" style="color:var(--text-muted)">Not uploaded</div> }
            </div>
            <div class="asset-preview-card">
                <div class="detail-label">Launch image</div>
                @if (!string.IsNullOrEmpty(Model.LaunchImagePath)) { <img src="@Model.LaunchImagePath" alt="Launch image" /> }
                else { <div class="detail-value" style="color:var(--text-muted)">Not uploaded</div> }
            </div>
            <div class="asset-preview-card">
                <div class="detail-label">Store icon</div>
                @if (!string.IsNullOrEmpty(Model.StoreIconPath)) { <img src="@Model.StoreIconPath" alt="Store icon" /> }
                else { <div class="detail-value" style="color:var(--text-muted)">Not uploaded</div> }
            </div>
            <div class="asset-preview-card">
                <div class="detail-label">Feature graphic</div>
                @if (!string.IsNullOrEmpty(Model.FeatureGraphicPath)) { <img src="@Model.FeatureGraphicPath" alt="Feature graphic" /> }
                else { <div class="detail-value" style="color:var(--text-muted)">Not uploaded</div> }
            </div>
        </div>
    </div>
</div>

<div class="section">
    <div class="section-header">
        <div class="section-icon icon-onesignal">
            <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        </div>
        <div class="section-title-group">
            <div class="section-title">OneSignal notification</div>
        </div>
    </div>
    <div class="section-body">
        <div class="detail-grid">
            <div class="detail-item"><div class="detail-label">Sender ID</div><div class="detail-value">@Model.OneSignalSenderId</div></div>
            <div class="detail-item"><div class="detail-label">App ID</div><div class="detail-value">@Model.OneSignalAppId</div></div>
            <div class="detail-item detail-item--full"><div class="detail-label">Rest API Key</div><div class="detail-value">••••••••••••</div></div>
        </div>
    </div>
</div>

<div class="section">
    <div class="section-header">
        <div class="section-icon icon-firebase">
            <svg viewBox="0 0 24 24"><path d="M18 10h-4V6"/><path d="M14 10l7-7"/><path d="M6 14H2v8h8v-4"/><path d="M10 14l-7 7"/></svg>
        </div>
        <div class="section-title-group">
            <div class="section-title">Firebase config</div>
        </div>
    </div>
    <div class="section-body">
        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-label">GoogleService-Info.plist</div>
                <div class="detail-value">@(string.IsNullOrEmpty(Model.FirebaseIosConfigPath) ? "Not uploaded" : "Uploaded")</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">google-services.json</div>
                <div class="detail-value">@(string.IsNullOrEmpty(Model.FirebaseAndroidConfigPath) ? "Not uploaded" : "Uploaded")</div>
            </div>
        </div>
    </div>
</div>

<div class="section">
    <div class="section-header">
        <div class="section-icon icon-contact">
            <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="section-title-group">
            <div class="section-title">Contact information</div>
        </div>
    </div>
    <div class="section-body">
        <div class="detail-grid">
            <div class="detail-item"><div class="detail-label">First name</div><div class="detail-value">@Model.ContactFirstName</div></div>
            <div class="detail-item"><div class="detail-label">Last name</div><div class="detail-value">@Model.ContactLastName</div></div>
            <div class="detail-item"><div class="detail-label">Phone</div><div class="detail-value">@Model.ContactPhoneNumber</div></div>
            <div class="detail-item"><div class="detail-label">Email</div><div class="detail-value">@Model.ContactEmailAddress</div></div>
            <div class="detail-item detail-item--full"><div class="detail-label">Privacy policy URL</div><div class="detail-value"><a href="@Model.PrivacyPolicyUrl" target="_blank" rel="noopener">@Model.PrivacyPolicyUrl</a></div></div>
        </div>
    </div>
</div>

<p class="meta-line">Created @Model.CreatedDate.ToString("MMM d, yyyy h:mm tt") · Modified @(Model.ModifiedDate?.ToString("MMM d, yyyy h:mm tt") ?? "—")</p>

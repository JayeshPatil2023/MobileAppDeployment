@model IEnumerable<MobileAppDeployment.Models.AppDeployment>
@{
    ViewData["Title"] = "App Deployments";
}

<div class="page-header-row">
    <div>
        <p class="page-title" style="margin-bottom:0">App deployments</p>
        <p class="page-sub" style="margin-bottom:0">Manage mobile app store submission configurations</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ New deployment</a>
</div>

<div class="data-card" style="margin-bottom:1.5rem; padding:1.25rem;">
    <p class="page-sub" style="margin-bottom:1rem;">Trigger merge workflow with client assets</p>
    <form asp-action="TriggerWorkflow" method="post" enctype="multipart/form-data" class="workflow-trigger-form">
        @Html.AntiForgeryToken()
        <div class="workflow-trigger-form__grid">
            <div>
                <label class="form-label" for="clientName">Client name</label>
                <input type="text"
                       id="clientName"
                       name="clientName"
                       placeholder="e.g. BidMaster"
                       class="form-control"
                       required />
            </div>
            <div>
                <label class="form-label" for="logoFile">Logo (PNG)</label>
                <input type="file"
                       id="logoFile"
                       name="logoFile"
                       accept=".png,image/png"
                       class="form-control"
                       required />
            </div>
            <div>
                <label class="form-label" for="splashFile">Splash (PNG)</label>
                <input type="file"
                       id="splashFile"
                       name="splashFile"
                       accept=".png,image/png"
                       class="form-control"
                       required />
            </div>
            <div>
                <label class="form-label" for="appBundleId">App bundle ID</label>
                <input type="text"
                       id="appBundleId"
                       name="appBundleId"
                       placeholder="com.systenics.myapp"
                       class="form-control"
                       required />
            </div>
            <div>
                <label class="form-label" for="appId">OneSignal App ID</label>
                <input type="text"
                       id="appId"
                       name="appId"
                       placeholder="UUID"
                       class="form-control"
                       required />
            </div>
            <div>
                <label class="form-label" for="projectId">OneSignal Project ID</label>
                <input type="text"
                       id="projectId"
                       name="projectId"
                       placeholder="Numeric project ID"
                       class="form-control"
                       required />
            </div>
            <div class="workflow-trigger-form__action">
                <button type="submit" class="btn btn-outline">Trigger Build Workflow</button>
            </div>
        </div>
    </form>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-banner alert-banner--success" role="alert">
        <span>@TempData["SuccessMessage"]</span>
        <button type="button" class="alert-close" data-dismiss="alert" aria-label="Close">&times;</button>
    </div>
}

@if (TempData["WarningMessage"] != null)
{
    <div class="alert-banner alert-banner--warn" role="alert">
        <span>@TempData["WarningMessage"]</span>
        <button type="button" class="alert-close" data-dismiss="alert" aria-label="Close">&times;</button>
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <p>No app deployments yet. Create your first submission configuration to get started.</p>
        <a asp-action="Create" class="btn btn-primary">Create deployment</a>
    </div>
}
else
{
    <div class="data-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>App name</th>
                    <th>Common name</th>
                    <th>Organization</th>
                    <th>Contact</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.AppName</strong></td>
                        <td class="cell-muted">@item.CommonName</td>
                        <td class="cell-muted">@item.OrganizationName</td>
                        <td class="cell-muted">@item.ContactFirstName @item.ContactLastName</td>
                        <td class="cell-muted">@item.CreatedDate.ToString("MMM d, yyyy")</td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline btn-outline--danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@model MobileAppDeployment.Models.AppDeployment
@{
    var isEdit = Model.Id > 0;
}

<div class="section" id="sec-mobile-config">
    <div class="section-header">
        <div class="section-icon icon-mobile">
            <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        </div>
        <div class="section-title-group">
            <div class="section-title">Mobile configuration</div>
        </div>
    </div>
    <div class="section-body">

        <div class="subsection">
            <div class="subsection-header">
                <div class="subsection-icon sub-android">
                    <svg viewBox="0 0 24 24"><path d="M6 18c0 .55.45 1 1 1h1v3.5a1.5 1.5 0 003 0V19h2v3.5a1.5 1.5 0 003 0V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 9.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3zm17 0a1.5 1.5 0 100-3 1.5 1.5 0 000 3zM8.5 4.5l1-2M15.5 4.5l-1-2"/></svg>
                </div>
                <span class="subsection-title">Android settings</span>
            </div>
            <div class="grid-2">
                <div class="field">
                    <div class="field-label-row">
                        <div class="field-label-wrap">
                            <label asp-for="AndroidPackageName" class="field-label">Package name <span class="required">*</span></label>
                            <field-help key="AndroidPackageName" />
                        </div>
                        <a href="https://developer.android.com/studio/build/configure-app-module#set-application-id" class="field-doc-link" target="_blank" rel="noopener noreferrer">
                            Android docs
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        </a>
                    </div>
                    <input asp-for="AndroidPackageName" class="form-input mono-input" placeholder="com.acmecorp.app" />
                    <span asp-validation-for="AndroidPackageName" class="field-error"></span>
                    <span class="field-hint">Unique app ID on Google Play. Once published, this cannot change.</span>
                </div>
                <div class="field">
                    <div class="field-label-wrap">
                        <label asp-for="GooglePlayListingUrl" class="field-label">Google Play listing URL</label>
                        <field-help key="GooglePlayListingUrl" />
                    </div>
                    <input asp-for="GooglePlayListingUrl" class="form-input" type="url" placeholder="https://play.google.com/store/apps/details?id=com.acmecorp.app" />
                    <span asp-validation-for="GooglePlayListingUrl" class="field-error"></span>
                    <span class="field-hint">Leave blank if not yet published — the build pipeline will create a new listing.</span>
                </div>
            </div>
            <div class="config-upload-item spacer">
                <div class="@Html.UploadZoneClasses("playStoreKeyFile", !string.IsNullOrEmpty(Model.PlayStoreKeyPath), "config-upload-zone")"
                     data-upload-zone="playStoreKeyFile" data-upload-type="config">
                    <svg viewBox="0 0 24 24"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
                    <div class="field-label-wrap field-label-wrap--upload">
                        <span class="upload-label">Play Store Key (JSON) <span class="required">*</span></span>
                        <field-help key="PlayStoreKeyFile" />
                    </div>
                    <span class="upload-spec">Upload Google Play service-account key JSON</span>
                    <span class="upload-filename"></span>
                </div>
                <input type="file" id="playStoreKeyFile" name="playStoreKeyFile" class="file-hidden"
                       accept=".json,application/json" data-has-existing="@(isEdit && !string.IsNullOrEmpty(Model.PlayStoreKeyPath) ? "true" : "false")" />
                @Html.ValidationMessage("playStoreKeyFile", "", new { @class = "field-error", data_valmsg_for = "playStoreKeyFile", data_valmsg_replace = "true" })
            </div>
        </div>

        <div class="subsection">
            <div class="subsection-header">
                <div class="subsection-icon sub-ios">
                    <svg viewBox="0 0 24 24"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0017 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 00-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06z"/><path d="M10 2c1 .5 2 2 2 5"/></svg>
                </div>
                <span class="subsection-title">iOS settings</span>
            </div>
            <div class="grid-2">
                <div class="field">
                    <div class="field-label-row">
                        <div class="field-label-wrap">
                            <label asp-for="IosBundleId" class="field-label">Bundle ID <span class="required">*</span></label>
                            <field-help key="IosBundleId" />
                        </div>
                        <a href="https://developer.apple.com/documentation/appstoreconnectapi/bundle_ids" class="field-doc-link" target="_blank" rel="noopener noreferrer">
                            App Store docs
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        </a>
                    </div>
                    <input asp-for="IosBundleId" class="form-input mono-input" placeholder="com.acmecorp.app" />
                    <span asp-validation-for="IosBundleId" class="field-error"></span>
                    <span class="field-hint">Must match exactly what's registered in App Store Connect.</span>
                </div>
                <div class="field">
                    <div class="field-label-row">
                        <div class="field-label-wrap">
                            <label asp-for="AppleTeamId" class="field-label">Apple Team ID <span class="required">*</span></label>
                            <field-help key="AppleTeamId" />
                        </div>
                        <a href="https://developer.apple.com/account#MembershipDetailsCard" class="field-doc-link" target="_blank" rel="noopener noreferrer">
                            Find it
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        </a>
                    </div>
                    <input asp-for="AppleTeamId" class="form-input mono-input" placeholder="A1B2C3D4E5" maxlength="10" />
                    <span asp-validation-for="AppleTeamId" class="field-error"></span>
                    <span class="field-hint">10-character alphanumeric ID from your Apple Developer membership page.</span>
                </div>
            </div>
            <div class="grid-2 spacer">
                <div class="field">
                    <div class="field-label-wrap">
                        <label asp-for="AppleIssuerId" class="field-label">Issuer ID <span class="required">*</span></label>
                        <field-help key="AppleIssuerId" />
                    </div>
                    <input asp-for="AppleIssuerId" class="form-input mono-input" placeholder="Issuer ID from App Store Connect API key" />
                    <span asp-validation-for="AppleIssuerId" class="field-error"></span>
                </div>
                <div class="field">
                    <div class="field-label-wrap">
                        <label asp-for="AppleKeyId" class="field-label">Key ID <span class="required">*</span></label>
                        <field-help key="AppleKeyId" />
                    </div>
                    <input asp-for="AppleKeyId" class="form-input mono-input" placeholder="10-character key ID" />
                    <span asp-validation-for="AppleKeyId" class="field-error"></span>
                </div>
            </div>
            <div class="config-upload-item spacer">
                <div class="@Html.UploadZoneClasses("appleAuthKeyFile", !string.IsNullOrEmpty(Model.AppleAuthKeyPath), "config-upload-zone")"
                     data-upload-zone="appleAuthKeyFile" data-upload-type="config">
                    <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <div class="field-label-wrap field-label-wrap--upload">
                        <span class="upload-label">Auth Key (.p8) <span class="required">*</span></span>
                        <field-help key="AppleAuthKeyFile" />
                    </div>
                    <span class="upload-spec">Upload App Store Connect API auth key (.p8)</span>
                    <span class="upload-filename"></span>
                </div>
                <input type="file" id="appleAuthKeyFile" name="appleAuthKeyFile" class="file-hidden"
                       accept=".p8,application/octet-stream,text/plain" data-has-existing="@(isEdit && !string.IsNullOrEmpty(Model.AppleAuthKeyPath) ? "true" : "false")" />
                @Html.ValidationMessage("appleAuthKeyFile", "", new { @class = "field-error", data_valmsg_for = "appleAuthKeyFile", data_valmsg_replace = "true" })
            </div>
        </div>

    </div>
</div>
